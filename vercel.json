{
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/about",
      "destination": "/call",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/call",
      "destination": "/about.html"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}
